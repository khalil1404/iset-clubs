{% extends 'base.html.twig' %}
{% block title %}Clubs — ISET Clubs{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>🏆 Tous les clubs</h1>
    {% if is_granted('ROLE_PRESIDENT') %}
        <a href="{{ path('app_club_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Créer un club
        </a>
    {% endif %}
</div>

<div class="row g-3">
    {% for club in clubs %}
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    {% if club.logo %}
                        <img src="/uploads/logos/{{ club.logo }}"
                             class="rounded-circle mb-3"
                             width="80" height="80" style="object-fit:cover">
                    {% else %}
                        <div class="bg-primary rounded-circle d-inline-flex
                                    align-items-center justify-content-center mb-3"
                             style="width:80px;height:80px">
                            <i class="bi bi-people-fill text-white fs-2"></i>
                        </div>
                    {% endif %}
                    <h5>{{ club.name }}</h5>
                    <span class="badge bg-secondary mb-2">{{ club.domain }}</span>
                    <p class="text-muted small">{{ club.description|slice(0,100) }}...</p>
                </div>
                <div class="card-footer bg-transparent text-center">
                    <a href="{{ path('app_club_show', {id: club.id}) }}"
                       class="btn btn-outline-primary btn-sm">Voir le club</a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info">Aucun club disponible.</div>
        </div>
    {% endfor %}
</div>
{% endblock %}