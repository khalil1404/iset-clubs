{% extends 'base.html.twig' %}
{% block title %}Mes clubs{% endblock %}
{% block body %}
<h2 class="mb-4">🏆 Mes clubs</h2>
{% if memberships %}
    <div class="row g-3">
        {% for membership in memberships %}
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h5>{{ membership.club.name }}</h5>
                        <span class="badge bg-secondary">{{ membership.role }}</span>
                        <p class="text-muted small mt-2">
                            Membre depuis {{ membership.joinedAt|date('d/m/Y') }}
                        </p>
                        <a href="{{ path('app_club_show', {id: membership.club.id}) }}"
                           class="btn btn-outline-primary btn-sm">Voir le club</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="alert alert-info">
        Vous n'êtes membre d'aucun club.
        <a href="{{ path('app_club_index') }}">Découvrir les clubs</a>
    </div>
{% endif %}
{% endblock %}