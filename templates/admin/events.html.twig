{% extends 'base.html.twig' %}
{% block title %}Événements — Admin{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-2">{% include 'admin/_sidebar.html.twig' %}</div>
    <div class="col-md-10">
        <h2 class="mb-4">📅 Gestion des événements</h2>
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nom</th><th>Club</th>
                            <th>Date</th><th>Statut</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in events %}
                            <tr>
                                <td>{{ event.nomEvenement }}</td>
                                <td>{{ event.club.name }}</td>
                                <td>{{ event.dateDebut|date('d/m/Y') }}</td>
                                <td>
                                    <span class="badge {{
                                        event.status == 'approved' ? 'bg-success' :
                                        (event.status == 'pending' ? 'bg-warning text-dark' : 'bg-danger')
                                    }}">{{ event.status }}</span>
                                </td>
                                <td>
                                    {% if event.status == 'pending' %}
                                        <a href="{{ path('app_admin_event_approve', {id: event.id}) }}"
                                           class="btn btn-success btn-sm">✓</a>
                                        <a href="{{ path('app_admin_event_reject', {id: event.id}) }}"
                                           class="btn btn-danger btn-sm">✗</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}