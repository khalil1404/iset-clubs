```twig
<div class="row g-3 mb-4">

    <div class="col-md-3">
        <div class="card bg-primary text-white text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-people fs-1"></i>
                <h2>{{ totalUsers }}</h2>
                <p class="mb-0">Utilisateurs</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-success text-white text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-award fs-1"></i>
                <h2>{{ totalClubs }}</h2>
                <p class="mb-0">Clubs</p>

                {% if pendingClubs > 0 %}
                    <span class="badge bg-warning text-dark">
                        {{ pendingClubs }} en attente
                    </span>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-info text-white text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-calendar-event fs-1"></i>
                <h2>{{ totalEvents }}</h2>
                <p class="mb-0">Événements</p>

                {% if pendingEvents > 0 %}
                    <span class="badge bg-warning text-dark">
                        {{ pendingEvents }} en attente
                    </span>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-warning text-white text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-briefcase fs-1"></i>
                <h2>{{ totalCandidatures }}</h2>
                <p class="mb-0">Candidatures</p>

                {% if pendingCandidatures > 0 %}
                    <span class="badge bg-dark">
                        {{ pendingCandidatures }} en attente
                    </span>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-danger text-white text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-chat-dots fs-1"></i>
                <h2>{{ totalReclamations }}</h2>
                <p class="mb-0">Réclamations</p>

                {% if pendingReclamations > 0 %}
                    <span class="badge bg-dark">
                        {{ pendingReclamations }} en attente
                    </span>
                {% endif %}
            </div>
        </div>
    </div>

</div>
```
