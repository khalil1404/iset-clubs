{% extends 'base.html.twig' %}
{% block title %}Utilisateurs — Admin{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-2">{% include 'admin/_sidebar.html.twig' %}</div>
    <div class="col-md-10">
        <h2 class="mb-4">👥 Utilisateurs</h2>
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th><th>Nom</th><th>Email</th>
                            <th>Rôle</th><th>Vérifié</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr>
                                <td>{{ user.id }}</td>
                                <td>{{ user.fullName }}</td>
                                <td>{{ user.email }}</td>
                                <td>
                                    {% for role in user.roles %}
                                        {% if role != 'ROLE_USER' %}
                                            <span class="badge bg-primary">{{ role }}</span>
                                        {% endif %}
                                    {% endfor %}
                                </td>
                                <td>
                                    {% if user.isVerified %}
                                        <span class="badge bg-success">Oui</span>
                                    {% else %}
                                        <span class="badge bg-danger">Non</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}