{% extends 'base.html.twig' %}
{% block title %}Mes événements{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📅 Événements de {{ club.name }}</h2>
    <a href="{{ path('app_event_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Créer un événement
    </a>
</div>
<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr><th>Nom</th><th>Date</th><th>Lieu</th><th>Statut</th></tr>
        </thead>
        <tbody>
            {% for event in events %}
                <tr>
                    <td>{{ event.nomEvenement }}</td>
                    <td>{{ event.dateDebut|date('d/m/Y') }}</td>
                    <td>{{ event.lieu }}</td>
                    <td>
                        <span class="badge {{
                            event.status == 'approved' ? 'bg-success' :
                            (event.status == 'pending' ? 'bg-warning text-dark' : 'bg-danger')
                        }}">{{ event.status }}</span>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-center">Aucun événement.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}