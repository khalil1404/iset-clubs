{% extends 'base.html.twig' %}
{% block title %}Mon Club{% endblock %}
{% block body %}
<div class="container py-4">
    {% if club %}
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>⭐ {{ club.name }}</h2>
            <span class="badge {{ club.status == 'approved' ? 'bg-success' : 'bg-warning text-dark' }} fs-6">
                {{ club.status == 'approved' ? 'Approuvé ✓' : 'En attente' }}
            </span>
        </div>
        <div class="card mb-4">
            <div class="card-body">
                <p>{{ club.description }}</p>
                <p><strong>Domaine :</strong> {{ club.domain }}</p>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-4">
                <a href="{{ path('app_president_events') }}" class="btn btn-primary w-100">
                    <i class="bi bi-calendar-event"></i> Mes événements
                </a>
            </div>
            <div class="col-md-4">
                <a href="{{ path('app_recruitment_index') }}" class="btn btn-success w-100">
                    <i class="bi bi-briefcase"></i> Recrutements
                </a>
            </div>
            <div class="col-md-4">
                <a href="{{ path('app_president_candidatures') }}" class="btn btn-info w-100">
                    <i class="bi bi-people"></i> Candidatures reçues
                </a>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning">
            Vous n'avez pas encore de club.
            <a href="{{ path('app_club_new') }}">Créer un club</a>
        </div>
    {% endif %}
</div>
{% endblock %}