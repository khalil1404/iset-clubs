{% extends 'base.html.twig' %}
{% block title %}Mes Clubs{% endblock %}
{% block body %}
<div class="container py-4">
    <h2>🎓 Mes Clubs</h2>

    {% if memberships is empty %}
        <div class="alert alert-info">
            Vous n'êtes membre d'aucun club pour le moment.
            <a href="{{ path('app_club_index') }}">Découvrir les clubs</a>
        </div>
    {% else %}
        <div class="row">
            {% for membership in memberships %}
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">{{ membership.club.name }}</h5>
                            <p class="card-text text-muted">{{ membership.club.domain }}</p>
                            <a href="{{ path('app_club_show', {id: membership.club.id}) }}" 
                               class="btn btn-sm btn-primary">Voir le club</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}