{% extends 'base.html.twig' %}
{% block title %}Mon Club{% endblock %}
{% block body %}
{% if club %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>⭐ {{ club.name }}</h2>
        <span class="badge {{ club.status == 'approved' ? 'bg-success' : 'bg-warning text-dark' }} fs-6">
            {{ club.status == 'approved' ? 'Approuvé ✓' : 'En attente' }}
        </span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <a href="{{ path('app_event_new') }}" class="text-decoration-none">
                <div class="card text-center bg-primary text-white shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-calendar-plus fs-1"></i>
                        <p class="mb-0 mt-2">Créer un événement</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="{{ path('app_recruitment_new') }}" class="text-decoration-none">
                <div class="card text-center bg-success text-white shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-briefcase fs-1"></i>
                        <p class="mb-0 mt-2">Publier recrutement</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="{{ path('app_president_events') }}" class="text-decoration-none">
                <div class="card text-center bg-info text-white shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-calendar-event fs-1"></i>
                        <p class="mb-0 mt-2">Mes événements</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="{{ path('app_president_candidatures') }}" class="text-decoration-none">
                <div class="card text-center bg-warning text-dark shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-people fs-1"></i>
                        <p class="mb-0 mt-2">Candidatures reçues</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h5>Informations du club</h5>
            <p><strong>Domaine :</strong> {{ club.domain }}</p>
            <p><strong>Description :</strong> {{ club.description }}</p>
            {% if club.website %}
                <p><strong>Site web :</strong>
                    <a href="{{ club.website }}" target="_blank">{{ club.website }}</a>
                </p>
            {% endif %}
        </div>
    </div>
{% else %}
    <div class="alert alert-info">
        <p>Vous n'avez pas encore de club.</p>
        <a href="{{ path('app_club_new') }}" class="btn btn-primary">Créer mon club</a>
    </div>
{% endif %}
{% endblock %} 