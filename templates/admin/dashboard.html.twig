{% extends 'base.html.twig' %}
{% block title %}Dashboard Admin{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-2">
        {% include 'admin/_sidebar.html.twig' %}
    </div>
    <div class="col-md-10">
        <h2 class="mb-4">🛡️ Dashboard Administrateur</h2>
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white text-center shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-people fs-1"></i>
                        <h2>{{ totalUsers }}</h2>
                        <p class="mb-0">Utilisateurs</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white text-center shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-award fs-1"></i>
                        <h2>{{ totalClubs }}</h2>
                        <p class="mb-0">Clubs</p>
                        {% if pendingClubs > 0 %}
                            <span class="badge bg-warning text-dark">
                                {{ pendingClubs }} en attente
                            </span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white text-center shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-calendar-event fs-1"></i>
                        <h2>{{ totalEvents }}</h2>
                        <p class="mb-0">Événements</p>
                        {% if pendingEvents > 0 %}
                            <span class="badge bg-warning text-dark">
                                {{ pendingEvents }} en attente
                            </span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between">
                <strong>Derniers clubs soumis</strong>
                <a href="{{ path('app_admin_clubs') }}"
                   class="btn btn-sm btn-outline-primary">Voir tout</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nom</th>
                            <th>Domaine</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for club in recentClubs %}
                            <tr>
                                <td>{{ club.name }}</td>
                                <td>{{ club.domain }}</td>
                                <td>
                                    <span class="badge {{
                                        club.status == 'approved' ? 'bg-success' :
                                        (club.status == 'pending' ? 'bg-warning text-dark' : 'bg-danger')
                                    }}">{{ club.status }}</span>
                                </td>
                                <td>
                                    {% if club.status == 'pending' %}
                                        <a href="{{ path('app_admin_club_approve', {id: club.id}) }}"
                                           class="btn btn-success btn-sm">✓</a>
                                        <a href="{{ path('app_admin_club_reject', {id: club.id}) }}"
                                           class="btn btn-danger btn-sm">✗</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}