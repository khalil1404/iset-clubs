{% extends 'base.html.twig' %}
{% block title %}Réclamations — Admin{% endblock %}
{% block body %}
<div class="row">
    <div class="col-md-2">{% include 'admin/_sidebar.html.twig' %}</div>
    <div class="col-md-10">
        <h2 class="mb-4">📝 Réclamations</h2>
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr><th>Étudiant</th><th>Sujet</th><th>Message</th><th>Date</th><th>Statut</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        {% for r in reclamations %}
                            <tr>
                                <td>{{ r.user.fullName }}</td>
                                <td>{{ r.subject }}</td>
                                <td>{{ r.message|slice(0,50) }}...</td>
                                <td>{{ r.createdAt|date('d/m/Y') }}</td>
                                <td>
                                    <span class="badge {{
                                        r.status == 'resolved' ? 'bg-success' :
                                        (r.status == 'in_progress' ? 'bg-info' : 'bg-warning text-dark')
                                    }}">{{ r.status }}</span>
                                </td>
                                <td>
                                    {% if r.status != 'resolved' %}
                                        <a href="{{ path('app_admin_reclamation_resolve', {id: r.id}) }}"
                                           class="btn btn-success btn-sm">✓ Résoudre</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}